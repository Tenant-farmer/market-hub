# KRX Data Marketplace 무료 계정 (pykrx 필수, 2025-12-27부터 로그인 의무화)
KRX_ID=
KRX_PW=

# SEC EDGAR: 이름/이메일 형식 User-Agent 필수
EDGAR_USER_AGENT=

# 텔레그램 브리핑 (@BotFather 토큰 → 봇에게 메시지 → python -m src.jobs.briefing --setup)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 이후 단계 ---
# 키움 REST API (모의: mockapi.kiwoom.com)
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
KIWOOM_MOCK=1

# Alpaca 페이퍼
ALPACA_API_KEY=
ALPACA_API_SECRET=

# TV 웹훅 페이로드 검증용 시크릿
WEBHOOK_SECRET=

# --- 대시보드 접근/바인드 (로컬은 비워두면 무인증·localhost) ---
# VPS 외부 노출 시: DASH_HOST=0.0.0.0, DASH_PASS=강한비밀번호 (HTTPS 터널 경유 권장)
DASH_HOST=
DASH_USER=admin
DASH_PASS=

# --- 자동매매 청산/리스크 (비워두면 기본값) ---
# EXIT_ENABLED=1 이면 워커가 보유 포지션에 청산규칙 적용(손절/주도이탈) → SELL 신호
EXIT_ENABLED=
# EXIT_STOP_PCT=-8   EXIT_RS=0   EXIT_CHECK_SEC=300
# 추세이탈(20MA)은 백테스트상 휩쏘로 해로워 기본 off — 굳이 켜려면: EXIT_MA_ENABLED=1  EXIT_MA=20
# MAX_ORDER_USD=10000   MAX_ORDER_KRW=10000000   MAX_DAILY_ORDERS=20   KILL_SWITCH=
# --- 신호진입: 매수신호등(green)일 때 지수 자동매수 (기본 off) ---
# SIGNAL_ENTRY_ENABLED=1   SIGNAL_ENTRY_SYMBOL=SPY   SIGNAL_ENTRY_QTY=1   SIGNAL_ENTRY_CHECK_SEC=3600
# RECONCILE_SEC=300  (주문 체결상태 동기화 주기 — 항상 동작, 안전)
